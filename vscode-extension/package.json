{
  "name": "argos-vscode-extension",
  "displayName": "ARGOS Auto Review",
  "description": "Run ARGOS auto review with VS Code Copilot language models.",
  "version": "0.2.2",
  "private": true,
  "publisher": "argos",
  "repository": {
    "type": "git",
    "url": "https://github.com/aYosukeMakita/argos.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "argos.startAutoReview",
        "title": "%argos.commands.startAutoReview.title%"
      }
    ],
    "configuration": {
      "title": "ARGOS",
      "properties": {
        "argos.includeContext": {
          "type": "boolean",
          "default": true,
          "description": "Include changed files and common metadata files as additional review context."
        },
        "argos.contextBudget": {
          "type": "number",
          "default": 220000,
          "minimum": 0,
          "description": "Maximum number of characters of additional code context sent to each model request."
        },
        "argos.activePreset": {
          "type": "string",
          "default": "",
          "description": "Name of the ARGOS model preset to use as the default reviewer, examiner, and rebuttal selection."
        },
        "argos.presets": {
          "type": "object",
          "default": {},
          "description": "Named ARGOS model presets. Model values must be the user-visible model labels shown by VS Code, such as 'Claude Opus 4.7' or 'GPT-5.4'.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string",
                "description": "Display name for the preset."
              },
              "description": {
                "type": "string",
                "description": "Human-readable description for the preset."
              },
              "reviewer": {
                "type": "object",
                "description": "Reviewer model selection.",
                "required": [
                  "model"
                ],
                "properties": {
                  "model": {
                    "type": "string",
                    "description": "User-visible model label, such as 'Claude Opus 4.7'."
                  }
                },
                "additionalProperties": false
              },
              "examiner": {
                "type": "object",
                "description": "Examiner model selection.",
                "required": [
                  "model"
                ],
                "properties": {
                  "model": {
                    "type": "string",
                    "description": "User-visible model label, such as 'GPT-5.4'."
                  }
                },
                "additionalProperties": false
              },
              "rebuttal": {
                "type": "object",
                "description": "Rebuttal model selection.",
                "required": [
                  "model"
                ],
                "properties": {
                  "model": {
                    "type": "string",
                    "description": "User-visible model label, such as 'GPT-5.4'."
                  }
                },
                "additionalProperties": false
              }
            },
            "required": [
              "reviewer",
              "examiner",
              "rebuttal"
            ],
            "additionalProperties": false
          }
        }
      }
    }
  },
  "scripts": {
    "build": "vsce package --skip-license --out argos-vscode-extension-${npm_package_version}.vsix",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "tsc -p ./"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/vscode": "^1.101.0",
    "@vscode/vsce": "^3.6.0",
    "typescript": "^5.8.3"
  }
}
