{
  "name": "argos-vscode-extension",
  "displayName": "ARGOS Auto Review",
  "description": "Run ARGOS auto review with VS Code Copilot language models.",
  "version": "0.4.1",
  "private": true,
  "publisher": "argos",
  "files": [
    "dist/**",
    "assets/**",
    "package.json",
    "package.nls.json",
    "package.nls.ja.json",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aYosukeMakita/argos.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "node": ">=24 <25",
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "argos.startAutoReview",
        "title": "%argos.commands.startAutoReview.title%"
      }
    ],
    "configuration": {
      "title": "ARGOS",
      "properties": {
        "argos.includeContext": {
          "type": "boolean",
          "default": true,
          "description": "Include changed files and common metadata files as additional review context."
        },
        "argos.contextBudget": {
          "type": "number",
          "default": 220000,
          "minimum": 0,
          "description": "Maximum number of characters of additional code context sent to each model request."
        },
        "argos.generatePromptFile": {
          "type": "boolean",
          "default": true,
          "description": "Generate a .github/prompts/*.prompt.md file for asking Copilot follow-up questions about each completed ARGOS review."
        },
        "argos.includeUncommittedChanges": {
          "type": "boolean",
          "default": true,
          "description": "Include committed changes plus staged changes and unstaged changes to tracked files in review diffs. Untracked files are not included."
        },
        "argos.activePreset": {
          "type": "string",
          "default": "",
          "description": "Name of the ARGOS model preset to use as the default reviewer, optional second reviewer, consolidator, examiner, and rebuttal selection."
        },
        "argos.presets": {
          "type": "object",
          "default": {},
          "description": "Named ARGOS model presets. Model values must be the user-visible model labels shown by VS Code, such as 'Claude Opus 4.7' or 'GPT-5.4'. Optional reviewer2 and consolidator entries must be defined together.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string",
                "description": "Display name for the preset."
              },
              "description": {
                "type": "string",
                "description": "Human-readable description for the preset."
              },
              "useSecondReviewer": {
                "type": "boolean",
                "description": "Whether to enable the second reviewer and consolidator by default for this preset. Defaults to true if reviewer2 is defined, false otherwise."
              },
              "reviewer": {
                "type": "object",
                "description": "Reviewer model selection.",
                "required": [
                  "model"
                ],
                "properties": {
                  "model": {
                    "type": "string",
                    "description": "User-visible model label, such as 'Claude Opus 4.7'."
                  }
                },
                "additionalProperties": false
              },
              "reviewer2": {
                "type": "object",
                "description": "Optional second initial reviewer model selection. Must be paired with consolidator.",
                "required": [
                  "model"
                ],
                "properties": {
                  "model": {
                    "type": "string",
                    "description": "User-visible model label, such as 'Claude Opus 4.8'."
                  }
                },
                "additionalProperties": false
              },
              "consolidator": {
                "type": "object",
                "description": "Optional consolidator model selection used to normalize multiple initial reviewer outputs. Must be paired with reviewer2.",
                "required": [
                  "model"
                ],
                "properties": {
                  "model": {
                    "type": "string",
                    "description": "User-visible model label, such as 'Claude Sonnet 4.6' or 'GPT-5.4'."
                  }
                },
                "additionalProperties": false
              },
              "examiner": {
                "type": "object",
                "description": "Examiner model selection.",
                "required": [
                  "model"
                ],
                "properties": {
                  "model": {
                    "type": "string",
                    "description": "User-visible model label, such as 'GPT-5.4'."
                  }
                },
                "additionalProperties": false
              },
              "rebuttal": {
                "type": "object",
                "description": "Rebuttal model selection.",
                "required": [
                  "model"
                ],
                "properties": {
                  "model": {
                    "type": "string",
                    "description": "User-visible model label, such as 'GPT-5.4'."
                  }
                },
                "additionalProperties": false
              }
            },
            "required": [
              "reviewer",
              "examiner",
              "rebuttal"
            ],
            "additionalProperties": false
          }
        }
      }
    }
  },
  "scripts": {
    "build": "vsce package --skip-license --out argos-vscode-extension-${npm_package_version}.vsix",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "tsc -p ./"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@types/vscode": "^1.120.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^6.0.3"
  }
}
